# Deeply Analytics — environment variables (example)
# Copy to .env and adjust per environment. The .env file is loaded automatically
# by backend/config.py on startup. Defaults in config.py keep the app running
# even if .env is missing — these values just override them.

# --- Environment ---
ENV=dev

# --- CORS ---
# JSON array of allowed origins. Production must list the frontend's HTTPS URL.
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Database ---
# Leave DATABASE_URL unset (or commented out) to use the local SQLite default
# stored at backend/storage/deeply.db. For Postgres production deployments:
#   postgresql+psycopg://user:password@host:port/database
# DATABASE_URL=postgresql+psycopg://deeply:deeply@localhost:5432/deeply

# Used by docker-compose.yml to provision the local Postgres service.
POSTGRES_USER=deeply
POSTGRES_PASSWORD=deeply
POSTGRES_DB=deeply

# --- JWT / authentication ---
# Generate a strong secret in production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# In production this MUST NOT be the literal "change-me-in-production" — the
# token helpers refuse to issue tokens with the placeholder outside dev mode.
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
# Legacy single TTL (kept for back-compat). New code uses the two below.
JWT_TTL_SECONDS=3600
# Access tokens: short-lived; sent on every request.
JWT_ACCESS_TTL_SECONDS=900
# Refresh tokens: long-lived; stored hashed in DB so they can be revoked.
JWT_REFRESH_TTL_SECONDS=2592000
# Minimum password length enforced by /auth/register.
PASSWORD_MIN_LENGTH=8

# --- Storage ---
# Local filesystem root for dev. In production this is replaced by S3-compatible
# object storage (future work).
STORAGE_ROOT=./backend/storage

# --- AI / inference ---
MODEL_CHECKPOINT=outputs/checkpoints/best_model.pth
IMAGE_SIZE=256
THRESHOLD=0.7
MIN_AREA=5

# --- Upload limits ---
# 50 MB
MAX_UPLOAD_BYTES=52428800

# --- Rate limits ---
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_MINUTE=5
RATE_LIMIT_REPORTS_PER_MINUTE=60
