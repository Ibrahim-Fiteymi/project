# Deeply Analytics — environment variables (example)
# Copy to .env and adjust per environment. The .env file is loaded automatically
# by backend/config.py on startup. Defaults in config.py keep the app running
# even if .env is missing — these values just override them.

# --- Environment ---
ENV=dev

# --- CORS ---
# JSON array of allowed origins. Production must list the frontend's HTTPS URL.
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Database (Phase 1 step 2+; ignored until then) ---
# Format for SQLAlchemy/SQLModel:
#   postgresql+psycopg://user:password@host:port/database
DATABASE_URL=postgresql+psycopg://deeply:deeply@localhost:5432/deeply

# Used by docker-compose.yml to provision the local Postgres service.
POSTGRES_USER=deeply
POSTGRES_PASSWORD=deeply
POSTGRES_DB=deeply

# --- JWT (Phase 1 step 3+; ignored until then) ---
# Generate a strong secret in production: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
JWT_TTL_SECONDS=3600

# --- Storage ---
# Local filesystem root for dev. In production this is replaced by S3-compatible
# object storage (Phase 2 step 13).
STORAGE_ROOT=./backend/storage

# --- AI / inference ---
MODEL_CHECKPOINT=outputs/checkpoints/best_model.pth
IMAGE_SIZE=256
THRESHOLD=0.8
MIN_AREA=1

# --- Upload limits ---
# 25 MB
MAX_UPLOAD_BYTES=26214400

# --- Rate limits (Phase 2; ignored until then) ---
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_MINUTE=30
RATE_LIMIT_REPORTS_PER_MINUTE=60
